runAfterLoad(function () {

    function hideAllExceptSand() {

        for (var el in elements) {
            if (!elements[el]) continue;

            elements[el].hidden = true;
        }

        if (elements["sand"]) {
            elements["sand"].hidden = false;
        }
    }

    // run immediately
    hideAllExceptSand();

    // run again after a short delay (fixes overwrite issues)
    setTimeout(hideAllExceptSand, 500);

});
